{
  "hooks": {
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "Git Status",
            "type": "command",
            "command": "git status --short"
          }
        ]
      }
    ]
  },
  "mcp": {
    "excluded": [
      "github",
      "postgres-db"
    ]
  },
  "mcpServers": {
    "github": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "${GITHUB_PERSONAL_ACCESS_TOKEN}"
      }
    },
    "git-history": {
      "command": "uvx",
      "args": [
        "mcp-server-git"
      ],
      "env": {}
    },
    "local-filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "."
      ],
      "env": {}
    },
    "fetch": {
      "command": "uvx",
      "args": [
        "mcp-server-fetch"
      ],
      "env": {}
    },
    "web-search": {
      "command": "npx",
      "args": [
        "-y",
        "@oevortex/ddg_search"
      ],
      "env": {}
    },
    "postgres-db": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres"
      ],
      "env": {
        "PGHOST": "${PGHOST}",
        "PGPORT": "${PGPORT}",
        "PGDATABASE": "${PGDATABASE}",
        "PGUSER": "${PGUSER}",
        "PGPASSWORD": "${PGPASSWORD}"
      }
    },
    "memory": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ],
      "env": {}
    },
    "sequential-thinking": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "env": {}
    },
    "large-file": {
      "command": "npx",
      "args": [
        "-y",
        "@willianpinho/large-file-mcp"
      ],
      "env": {}
    },
    "markdown-tools": {
      "command": "npx",
      "args": [
        "-y",
        "@dougis/markdown-lint-mcp"
      ],
      "env": {}
    }
  }
}