echo "Preparing configuration targets..."
mkdir -p "$WORKSPACE_DIR"
mkdir -p "$HOME/.config/Kiro"
mkdir -p "$HOME/.gemini"

echo "Assembling unified workspace config..."
cat << EOF > "$MASTER_CONF"
{
  "mcpServers": {
    "my-local-filesystem": {
      "command": "uvx",
      "args": [
        "--with",
        "editable+$WORKSPACE_DIR/packages/service-filesystem",
        "my-filesystem-package-name"
      ]
    },
    "my-local-database": {
      "command": "uvx",
      "args": [
        "--with",
        "editable+$WORKSPACE_DIR/packages/service-database",
        "my-database-package-name"
      ]
    },
    "official-memory": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-memory"]
    },
    "sequential-thinking": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-sequential-thinking"]
    }
  }
}
EOF

echo "Routing compiled target files directly to tool environments..."
cp "$MASTER_CONF" "$HOME/.gemini/settings.json"
cp "$MASTER_CONF" "$HOME/.config/Kiro/mcp_config.json"

echo "Success! UV workspace configuration mapped and deployed."

